{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-software-studio.local/studio-loop/agent/planner-output.schema.json",
  "title": "Planner final output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "role", "feature_id", "run_id", "invocation_id",
    "decision", "summary", "artifact_paths", "validation_profile_ids", "risks"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "role": {"const": "planner"},
    "feature_id": {"$ref": "#/$defs/featureId"},
    "run_id": {"$ref": "#/$defs/id"},
    "invocation_id": {"$ref": "#/$defs/id"},
    "decision": {"enum": ["artifacts_ready", "blocked"]},
    "summary": {"$ref": "#/$defs/summary"},
    "artifact_paths": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"$ref": "#/$defs/path"}},
    "validation_profile_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"}
    },
    "risks": {"type": "array", "maxItems": 32, "items": {"$ref": "#/$defs/summary"}}
  },
  "$defs": {
    "featureId": {"type": "string", "pattern": "^[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "id": {"type": "string", "minLength": 8, "maxLength": 128},
    "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
    "path": {"type": "string", "minLength": 1, "maxLength": 512, "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}
  }
}
