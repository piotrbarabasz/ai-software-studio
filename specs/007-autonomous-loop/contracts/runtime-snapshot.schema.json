{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-software-studio.local/studio-loop/runtime-snapshot.schema.json",
  "title": "Rebuildable Studio Loop runtime snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "controller_version", "feature_id", "run_id", "mode",
    "config_digest", "artifact_digest", "last_event_sequence", "last_event_sha256",
    "feature_state", "run_state", "stop_requested", "active_task_id", "tasks",
    "current_effect", "local_head_sha", "remote_sha", "draft_pr", "last_failure"
  ],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$"},
    "controller_version": {"type": "string", "minLength": 1},
    "feature_id": {"type": "string", "pattern": "^[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "run_id": {"type": "string", "minLength": 16},
    "mode": {"enum": ["dry-run", "local", "draft-pr"]},
    "config_digest": {"$ref": "#/$defs/digest"},
    "artifact_digest": {"$ref": "#/$defs/digest"},
    "last_event_sequence": {"type": "integer", "minimum": 0},
    "last_event_sha256": {"oneOf": [{"$ref": "#/$defs/digest"}, {"type": "null"}]},
    "feature_state": {"$ref": "#/$defs/featureState"},
    "run_state": {"enum": ["active", "stop_requested", "stopped", "completed", "blocked", "failed", "aborted", "reconciliation_required"]},
    "stop_requested": {"type": "boolean"},
    "active_task_id": {"oneOf": [{"type": "string", "pattern": "^T[0-9]{3,}$"}, {"type": "null"}]},
    "tasks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "attempts_used", "commit_sha"],
        "properties": {
          "status": {"$ref": "#/$defs/taskState"},
          "attempts_used": {"type": "integer", "minimum": 0, "maximum": 10},
          "commit_sha": {"oneOf": [{"$ref": "#/$defs/gitSha"}, {"type": "null"}]}
        }
      }
    },
    "current_effect": {"oneOf": [{"$ref": "#/$defs/effect"}, {"type": "null"}]},
    "local_head_sha": {"oneOf": [{"$ref": "#/$defs/gitSha"}, {"type": "null"}]},
    "remote_sha": {"oneOf": [{"$ref": "#/$defs/gitSha"}, {"type": "null"}]},
    "draft_pr": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["number", "url", "head_sha", "is_draft", "checks_state"],
          "properties": {
            "number": {"type": "integer", "minimum": 1},
            "url": {"type": "string", "format": "uri"},
            "head_sha": {"$ref": "#/$defs/gitSha"},
            "is_draft": {"type": "boolean"},
            "checks_state": {"enum": ["unknown", "pending", "passed", "failed", "cancelled", "missing", "indeterminate"]}
          }
        },
        {"type": "null"}
      ]
    },
    "last_failure": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["class", "code", "summary", "evidence"],
          "properties": {
            "class": {"type": "string", "minLength": 1},
            "code": {"type": "string", "minLength": 1},
            "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
            "evidence": {"type": "array", "items": {"type": "string"}}
          }
        },
        {"type": "null"}
      ]
    }
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "gitSha": {"type": "string", "pattern": "^[a-f0-9]{40,64}$"},
    "effect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effect_id", "kind", "idempotency_key", "status", "target_digest", "observed_result_digest"],
      "properties": {
        "effect_id": {"type": "string", "minLength": 1},
        "kind": {"enum": ["branch", "worktree", "invocation", "validation", "stage", "commit", "push", "draft_pr", "checks", "cleanup"]},
        "idempotency_key": {"type": "string", "minLength": 1, "maxLength": 512},
        "status": {"enum": ["intended", "succeeded", "failed", "ambiguous"]},
        "target_digest": {"$ref": "#/$defs/digest"},
        "observed_result_digest": {"oneOf": [{"$ref": "#/$defs/digest"}, {"type": "null"}]}
      }
    },
    "featureState": {
      "enum": [
        "proposed", "initialized", "planning", "ready", "executing",
        "locally_complete", "publishing", "ci_pending", "ci_repair", "stopped",
        "ready_for_manual_review", "blocked", "reconciliation_required", "failed", "aborted"
      ]
    },
    "taskState": {
      "enum": [
        "pending", "ready", "running", "validating", "reviewing", "committing",
        "retryable_failed", "reconciliation_required", "completed", "blocked", "failed", "aborted"
      ]
    }
  }
}
