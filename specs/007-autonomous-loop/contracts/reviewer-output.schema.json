{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-software-studio.local/studio-loop/agent/reviewer-output.schema.json",
  "title": "Reviewer final output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "role", "feature_id", "run_id", "task_id", "attempt_id",
    "invocation_id", "decision", "summary", "requirement_findings", "findings",
    "test_assessment", "diff_assessment"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "role": {"const": "reviewer"},
    "feature_id": {"$ref": "#/$defs/featureId"},
    "run_id": {"$ref": "#/$defs/id"},
    "task_id": {"$ref": "#/$defs/taskId"},
    "attempt_id": {"$ref": "#/$defs/id"},
    "invocation_id": {"$ref": "#/$defs/id"},
    "decision": {"enum": ["accept", "changes_requested", "blocked"]},
    "summary": {"$ref": "#/$defs/summary"},
    "requirement_findings": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requirement_id", "status", "evidence"],
        "properties": {
          "requirement_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*-[0-9]{3}$"},
          "status": {"enum": ["met", "not_met", "not_verifiable"]},
          "evidence": {"type": "array", "maxItems": 16, "items": {"$ref": "#/$defs/summary"}}
        }
      }
    },
    "findings": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "path", "summary"],
        "properties": {
          "code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,63}$"},
          "severity": {"enum": ["critical", "high", "medium", "low"]},
          "path": {"oneOf": [{"$ref": "#/$defs/path"}, {"type": "null"}]},
          "summary": {"$ref": "#/$defs/summary"}
        }
      }
    },
    "test_assessment": {"enum": ["sufficient", "insufficient", "not_applicable"]},
    "diff_assessment": {"enum": ["within_scope", "out_of_scope", "not_verifiable"]}
  },
  "$defs": {
    "featureId": {"type": "string", "pattern": "^[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "taskId": {"type": "string", "pattern": "^T[0-9]{3,}$"},
    "id": {"type": "string", "minLength": 8, "maxLength": 128},
    "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
    "path": {"type": "string", "minLength": 1, "maxLength": 512, "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}
  }
}
