{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-software-studio.local/studio-loop/tasks.schema.json",
  "title": "Canonical Studio Loop task set",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "feature_id", "requirements", "tasks"],
  "properties": {
    "schema_version": {"const": "1.1.0"},
    "feature_id": {"$ref": "#/$defs/featureId"},
    "requirements": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*-[0-9]{3}$"}
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {"$ref": "#/$defs/task"}
    }
  },
  "$defs": {
    "featureId": {"type": "string", "pattern": "^[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "taskId": {"type": "string", "pattern": "^T[0-9]{3,}$"},
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*[\\u0000-\\u001f]).+$"
    },
    "nonBlank": {"type": "string", "minLength": 1, "maxLength": 2000, "pattern": ".*\\S.*"},
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "phase", "title", "description", "dependencies", "requirement_ids",
        "allowed_read_paths", "allowed_write_paths", "writes", "validation_profiles",
        "completion_criteria", "tests", "attempt_budget"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/taskId"},
        "phase": {"type": "string", "pattern": "^P[0-9]{2}-[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "title": {"type": "string", "minLength": 1, "maxLength": 160},
        "description": {"$ref": "#/$defs/nonBlank"},
        "dependencies": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/taskId"}},
        "requirement_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*-[0-9]{3}$"}
        },
        "allowed_read_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/repositoryPath"}},
        "allowed_write_paths": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/repositoryPath"}},
        "writes": {"type": "boolean"},
        "validation_profiles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"}},
        "completion_criteria": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonBlank"}},
        "tests": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonBlank"}},
        "attempt_budget": {"type": "integer", "minimum": 1, "maximum": 10}
      },
      "allOf": [
        {
          "if": {"properties": {"writes": {"const": false}}, "required": ["writes"]},
          "then": {"properties": {"allowed_write_paths": {"maxItems": 0}}}
        },
        {
          "if": {"properties": {"writes": {"const": true}}, "required": ["writes"]},
          "then": {"properties": {"allowed_write_paths": {"minItems": 1}}}
        }
      ]
    }
  }
}
