# Production-only placeholders for AISoftware Studio GCP deployment

APP_ENV=production
CORS_ALLOWED_ORIGINS=https://<FRONTEND_CLOUD_RUN_URL>
CONTACT_DELIVERY_MODE=email
CONTACT_RECIPIENT_EMAIL=owner@example.com
CONTACT_FROM_EMAIL=noreply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=smtp-user@example.com
SMTP_USE_TLS=true
CONTACT_RATE_LIMIT_PER_MINUTE=5

# Secret Manager reference only, not a real value
SMTP_PASSWORD_SECRET=aisoftware-studio-smtp-password

# Optional deployment placeholders
PROJECT_ID=<PROJECT_ID>
REGION=europe-central2
ARTIFACT_REPO=aisoftware-studio
BACKEND_SERVICE_NAME=aisoftware-studio-api
FRONTEND_SERVICE_NAME=aisoftware-studio-web
BACKEND_IMAGE_NAME=aisoftware-studio-api
FRONTEND_IMAGE_NAME=aisoftware-studio-web
BACKEND_API_URL=https://<BACKEND_CLOUD_RUN_URL>
