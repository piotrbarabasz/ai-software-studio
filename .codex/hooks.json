{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Shell|shell|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_tool_use.py\"",
            "commandWindows": "powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command \"$root = git rev-parse --show-toplevel; & py -3 (Join-Path $root '.codex\\hooks\\pre_tool_use.py')\"",
            "timeout": 10,
            "statusMessage": "Checking Studio Loop policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Shell|shell|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/post_tool_use.py\"",
            "commandWindows": "powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command \"$root = git rev-parse --show-toplevel; & py -3 (Join-Path $root '.codex\\hooks\\post_tool_use.py')\"",
            "timeout": 10,
            "statusMessage": "Recording sanitized tool metadata"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/stop.py\"",
            "commandWindows": "powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command \"$root = git rev-parse --show-toplevel; & py -3 (Join-Path $root '.codex\\hooks\\stop.py')\"",
            "timeout": 5,
            "statusMessage": "Leaving continuation to Studio Loop controller"
          }
        ]
      }
    ]
  }
}
