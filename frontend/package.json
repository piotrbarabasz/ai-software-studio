{
  "name": "aisoftware-studio-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prestart": "npm run prepare:legal:local-test",
    "start": "ng serve --host 127.0.0.1 --port 4200",
    "prelint": "npm run prepare:legal:local-test",
    "prepare:site:production": "node scripts/write-production-environment.cjs",
    "prepare:hosting:production": "node scripts/generate-nginx-security-headers.cjs",
    "prepare:legal:local-test": "node scripts/write-local-test-legal-config.cjs",
    "prepare:legal:production": "node scripts/write-production-legal-config.cjs",
    "build": "npm run prepare:site:production && npm run prepare:legal:production && npm run validate:site:production && npm run prepare:hosting:production && npm run validate:legal:production && npm run generate:seo:production && npm run validate:seo:production && ng build --configuration production && npm run validate:site-artifact:production && npm run validate:artifact:production",
    "build:development": "npm run prepare:legal:local-test && npm run generate:seo:development && npm run validate:seo:development && ng build --configuration development",
    "check": "npm run format:check && npm run lint && npm test && npm run build",
    "validate:site:production": "node scripts/validate-public-site-config.cjs",
    "validate:site-artifact:production": "node scripts/validate-site-artifact.cjs",
    "generate:seo:production": "node scripts/generate-seo-artifacts.cjs production",
    "generate:seo:development": "node scripts/generate-seo-artifacts.cjs development",
    "validate:seo:production": "node scripts/validate-seo-artifacts.cjs production",
    "validate:seo:development": "node scripts/validate-seo-artifacts.cjs development",
    "validate:legal:production": "node scripts/validate-public-legal-config.cjs",
    "test:legal-config": "node --test scripts/validate-public-legal-config.test.cjs scripts/write-production-legal-config.test.cjs scripts/validate-production-artifact.test.cjs",
    "validate:artifact:production": "node scripts/validate-production-artifact.cjs",
    "validate:static-routes": "node scripts/validate-static-routes.cjs",
    "test:site-build": "node --test scripts/site-build-utils.test.cjs scripts/generate-nginx-security-headers.test.cjs scripts/validate-site-artifact.test.cjs scripts/write-production-environment.test.cjs",
    "test": "npm run prepare:legal:local-test && npm run validate:static-routes && npm run test:legal-config && npm run test:site-build && ng test --watch=false --browsers=ChromeHeadless",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\" \"scripts/**/*.{cjs,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\" \"scripts/**/*.{cjs,mjs}\""
  },
  "dependencies": {
    "@angular/common": "^17.3.12",
    "@angular/compiler": "^17.3.12",
    "@angular/core": "^17.3.12",
    "@angular/forms": "^17.3.12",
    "@angular/platform-browser": "^17.3.12",
    "@angular/platform-browser-dynamic": "^17.3.12",
    "@angular/platform-server": "^17.3.12",
    "@angular/router": "^17.3.12",
    "@angular/ssr": "^17.3.12",
    "rxjs": "~7.8.1",
    "tslib": "^2.6.3",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.12",
    "@angular/cli": "^17.3.12",
    "@angular/compiler-cli": "^17.3.12",
    "@types/jasmine": "~5.1.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jasmine-core": "~5.1.2",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.3.3",
    "typescript": "~5.4.5"
  }
}
