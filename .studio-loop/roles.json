{
  "schema_version": "1.0.0",
  "roles": {
    "planner": {
      "model": "gpt-5.6-sol",
      "reasoning_effort": "high",
      "sandbox": "read-only",
      "prompt_template": ".studio-loop/prompts/planner.md",
      "output_schema": ".studio-loop/schemas/planner-output.schema.json",
      "timeout_seconds": 900,
      "retry_output_parsing": 1,
      "max_output_bytes": 262144,
      "allowed_tools": ["repository-read", "shell-read"],
      "restrictions": ["no-git-mutation", "no-network", "no-secrets", "no-session-resume"]
    },
    "implementer": {
      "model": "gpt-5.6-terra",
      "reasoning_effort": "high",
      "sandbox": "workspace-write",
      "prompt_template": ".studio-loop/prompts/implementer.md",
      "output_schema": ".studio-loop/schemas/implementer-output.schema.json",
      "timeout_seconds": 1800,
      "retry_output_parsing": 1,
      "max_output_bytes": 262144,
      "allowed_tools": ["repository-read", "workspace-edit", "task-validation"],
      "restrictions": ["task-package-write-paths-only", "no-git-mutation", "no-network", "no-secrets", "no-session-resume"]
    },
    "reviewer": {
      "model": "gpt-5.6-sol",
      "reasoning_effort": "high",
      "sandbox": "read-only",
      "prompt_template": ".studio-loop/prompts/reviewer.md",
      "output_schema": ".studio-loop/schemas/reviewer-output.schema.json",
      "timeout_seconds": 900,
      "retry_output_parsing": 1,
      "max_output_bytes": 262144,
      "allowed_tools": ["repository-read", "shell-read"],
      "restrictions": ["no-writes", "no-git-mutation", "no-network", "no-secrets", "no-session-resume"]
    },
    "debugger": {
      "model": "gpt-5.6-terra",
      "reasoning_effort": "high",
      "sandbox": "workspace-write",
      "prompt_template": ".studio-loop/prompts/debugger.md",
      "output_schema": ".studio-loop/schemas/debugger-output.schema.json",
      "timeout_seconds": 1800,
      "retry_output_parsing": 1,
      "max_output_bytes": 262144,
      "allowed_tools": ["repository-read", "workspace-edit", "task-validation"],
      "restrictions": ["recorded-failure-required", "task-package-write-paths-only", "no-git-mutation", "no-network", "no-secrets", "no-session-resume"]
    }
  }
}
