{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-software-studio.local/studio-loop/failure-package.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "feature_id", "task_id", "failure_class", "summary"],
  "properties": {"schema_version": {"const": "1.0.0"}, "feature_id": {"type": "string", "pattern": "^[0-9]{3}-[a-z0-9]+(?:-[a-z0-9]+)*$"}, "task_id": {"type": ["string", "null"], "pattern": "^T[0-9]{3,}$"}, "failure_class": {"enum": ["schema", "policy", "validation", "review", "state", "graph"]}, "summary": {"type": "string", "minLength": 1}}
}
