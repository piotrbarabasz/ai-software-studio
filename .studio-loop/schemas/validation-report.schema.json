{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-software-studio.local/studio-loop/validation-report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "task_id", "profile_id", "passed", "summary"],
  "properties": {"schema_version": {"const": "1.0.0"}, "task_id": {"type": "string", "pattern": "^T[0-9]{3,}$"}, "profile_id": {"type": "string", "minLength": 1}, "passed": {"type": "boolean"}, "summary": {"type": "string", "minLength": 1}}
}
