{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-software-studio.local/studio-loop/validation-report.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["task_id", "passed", "required_profiles", "results"],
  "properties": {
    "task_id": {"type": "string", "pattern": "^T[0-9]{3,}$"},
    "passed": {"type": "boolean"},
    "required_profiles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 100}},
    "results": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/result"}}
  },
  "$defs": {
    "result": {
      "type": "object", "additionalProperties": false,
      "required": ["profile", "argv", "working_directory", "started_at", "ended_at", "exit_code", "stdout", "stderr", "truncated", "truncation_marker", "status"],
      "properties": {
        "profile": {"type": "string", "minLength": 1},
        "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "working_directory": {"type": "string"},
        "started_at": {"type": "string", "format": "date-time"},
        "ended_at": {"type": "string", "format": "date-time"},
        "exit_code": {"type": ["integer", "null"]},
        "stdout": {"type": "string"}, "stderr": {"type": "string"},
        "truncated": {"type": "boolean"}, "truncation_marker": {"type": ["string", "null"]},
        "status": {"enum": ["PASS", "FAIL", "TIMEOUT", "ERROR"]}
      }
    }
  }
}
