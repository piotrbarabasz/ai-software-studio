{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-software-studio.local/studio-loop/implementer-output.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "task_id", "summary", "claimed_changed_files", "commands_requested", "blocking_issues"],
  "properties": {
    "status": {"enum": ["implemented", "no_change_required", "blocked", "failed"]},
    "task_id": {"type": "string", "pattern": "^T[0-9]{3,}$"},
    "summary": {"type": "string", "minLength": 1, "maxLength": 4000},
    "claimed_changed_files": {"$ref": "#/$defs/paths"},
    "commands_requested": {"type": "array", "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"}},
    "blocking_issues": {"$ref": "#/$defs/findings"}
  },
  "$defs": {
    "path": {"type": "string", "minLength": 1, "maxLength": 512, "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "paths": {"type": "array", "maxItems": 128, "uniqueItems": true, "items": {"$ref": "#/$defs/path"}},
    "findings": {"type": "array", "maxItems": 64, "items": {"type": "string", "minLength": 1, "maxLength": 2000}}
  }
}
